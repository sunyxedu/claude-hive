# Claude Hive Configuration
# Copy to .env and adjust as needed

# Path to the project being managed
HIVE_PROJECT_DIR=/path/to/your/project
HIVE_PROJECT_NAME=my-project

# Server settings
HIVE_HOST=0.0.0.0
HIVE_PORT=8420

# Worker settings
HIVE_MAX_WORKERS=3
HIVE_WORKER_PORT_BASE=5200

# Claude CLI settings
HIVE_CLAUDE_CLI=claude
HIVE_CLAUDE_MODEL=
HIVE_PLAN_MODE_DEFAULT=true

# Git settings
HIVE_MAIN_BRANCH=main
HIVE_AUTO_PUSH=false
